  longitude                      Decimal?                  @db.Decimal(11, 8)
  mastrNumber                    String?
  controllerType                 String?                   // z.B. "CS82" — verknüpft mit ScadaStatusCode
  status                         EntityStatus              @default(ACTIVE)
  technicalData                  Json                      @default("{}")
