  leaseRevenueSettlementItems    LeaseRevenueSettlementItem[]
  leases                         Lease[]                          @relation("LeaseLessor")
  tenant                         Tenant                           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shareholders                   Shareholder[]
  contactType                    String?                          @db.VarChar(50)
  // P16: B2B-Flag für §288 BGB Verzugszinsen (B2B = Basis+9%-Pkt + 40€-Pauschale,
  // B2C = Basis+5%-Pkt). personType="natural" + isBusinessCustomer=false → B2C.
  // companyName gesetzt ODER isBusinessCustomer=true → B2B.
  isBusinessCustomer             Boolean                          @default(false)
  lastActivityAt                 DateTime?
  crmActivities                  CrmActivity[]
  vendorProfiles                 Vendor[]
  contactLinks                   ContactLink[]
  tags                           PersonTag[]                      @relation("PersonToPersonTag")

  @@index([tenantId])
  @@index([lastName, firstName])
  @@map("persons")
}

model Shareholder {
  id                     String               @id @default(uuid())
  shareholderNumber      String?
  entryDate              DateTime?
  exitDate               DateTime?
  capitalContribution    Decimal?             @db.Decimal(15, 2)
  liabilityAmount        Decimal?             @db.Decimal(15, 2)
  ownershipPercentage    Decimal?             @db.Decimal(8, 5)
  votingRightsPercentage Decimal?             @db.Decimal(8, 5)
