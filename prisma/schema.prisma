// P9: Periodensperre §146 AO (GoBD). Geschlossene Monate dürfen
// keine Buchungen mehr aufnehmen (weder neue Entries noch POST von DRAFTs).
// Unlock ist möglich, hinterlässt aber Audit-Trail (siehe unlockedAt/unlockedById).
model AccountingPeriodLock {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  periodYear   Int
  periodMonth  Int       // 1-12
  lockedAt     DateTime  @default(now())
  lockedById   String
  lockedBy     User      @relation("PeriodLocker", fields: [lockedById], references: [id], onDelete: Restrict)
  unlockedAt   DateTime?
  unlockedById String?
  unlockedBy   User?     @relation("PeriodUnlocker", fields: [unlockedById], references: [id], onDelete: Restrict)
  reason       String?   @db.VarChar(500)

  @@unique([tenantId, periodYear, periodMonth])
  @@index([tenantId, periodYear, periodMonth])
  @@map("accounting_period_locks")
}

/// P24.2: GoBD §147 AO Belegablage — Beleg-Dateien mit Hash an Buchung anhängen.
/// Ein JournalEntry kann mehrere Belege haben (Sammelbuchung) und ein Beleg
/// kann mehreren Buchungen zugeordnet sein (Beleg-Reuse).
model JournalAttachment {
  id              String       @id @default(uuid())
  tenantId        String
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  journalEntryId  String
  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  /// Original-Dateiname beim Upload.
  fileName        String       @db.VarChar(255)
  /// Storage-Pfad (S3-Key oder lokaler Pfad).
  fileUrl         String       @db.VarChar(500)
  /// MIME-Type.
  mimeType        String       @db.VarChar(100)
  /// SHA-256 Hex-Digest des Original-Inhalts. Wird beim Upload berechnet
  /// und niemals geändert — Veränderung des Inhalts erfordert neuen Beleg.
  fileHash        String       @db.VarChar(64)
  fileSizeBytes   BigInt
  /// Optionaler Anzeige-Text (z.B. "Rechnung Müller GmbH 06/2026").
  description     String?      @db.VarChar(500)
  uploadedById    String
  uploadedBy      User         @relation("JournalAttachmentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  uploadedAt      DateTime     @default(now())

  @@index([tenantId, journalEntryId])
  @@index([fileHash])
  @@map("journal_attachments")
}

model JournalEntry {
  id            String             @id @default(uuid())
  tenantId      String
  // AUDIT: tenantId is required — onDelete: Cascade kept because tenant deletion is rare
  // and should remove all financial data. For regulatory retention, archive before deletion.
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entryDate     DateTime
  description   String             @db.VarChar(200)
  reference     String?            @db.VarChar(100)
  status        JournalEntryStatus @default(DRAFT)
  source        PostingSource      @default(MANUAL)
  referenceType String?            @db.VarChar(50)
  referenceId   String?
  createdById   String
  createdBy     User               @relation("JournalEntryCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?
  lines         JournalEntryLine[]

  // P9: Storno-Verkettung (Generalumkehr für POSTED Journals).
  // reversesJournalEntryId: dieser Entry ist die Storno-Buchung von ...
  // reversedBy: dieser Entry wurde durch ... storniert (Rückrelation, kein eigenes FK-Feld nötig)
  reversesJournalEntryId String?       @unique
  reverses               JournalEntry? @relation("JournalReversal", fields: [reversesJournalEntryId], references: [id])
  reversedBy             JournalEntry? @relation("JournalReversal")
  reversalReason         String?       @db.VarChar(500)

  // P11: §17 USt-Korrektur die DIESEN Eintrag als Korrekturbuchung verwendet (1:1).
  ustAdjustment          UStAdjustment?
  // P24.2: GoBD §147 Beleg-Anhänge (n Beleg-PDFs pro Buchung).
  attachments            JournalAttachment[]
  // P16: Forderungsmanagement Rückrelationen.
  invoicePayments        InvoicePayment[] @relation("InvoicePaymentJournal")
  valueAdjustments       ValueAdjustment[] @relation("ValueAdjustmentJournal")

  @@index([tenantId])
  @@index([tenantId, entryDate])
  @@index([tenantId, status])
  @@index([referenceType, referenceId])
  @@map("journal_entries")
}

model JournalEntryLine {
  id             String       @id @default(uuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  lineNumber     Int
  account        String       @db.VarChar(20)
  accountName    String?      @db.VarChar(100)
  description    String?      @db.VarChar(200)
  debitAmount    Decimal?     @db.Decimal(15, 2)
  creditAmount   Decimal?     @db.Decimal(15, 2)
  taxKey         String?      @db.VarChar(10)
  costCenter     String?      @db.VarChar(50)

  // P10: optionaler Tax-Code-Verweis. Wird in P11/P12 für UStVA-Aggregation
  // genutzt (statt String-Match auf Kontonummer).
  taxCodeId      String?
  taxCode        TaxCode?     @relation(fields: [taxCodeId], references: [id], onDelete: SetNull)
  /// UStVA-Kennzahl direkt auf der Buchungszeile (überschreibt taxCode.vatReportBox
  /// falls beides gesetzt). Erlaubt Sonderfälle (z.B. Korrekturbuchungen mit
  /// abweichender Box).
  ustvaKennzahl  String?      @db.VarChar(10)

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([journalEntryId])
  // P-2 Sprint 2: Index für Account-basierte Reports (Kontoblatt, Bilanz, GuV, SuSa).
  // Vorher: Seq-Scan über alle Lines. Nachher: Index-Lookup pro Konto.
  @@index([account])
  @@index([account, journalEntryId])
  @@map("journal_entry_lines")
}

