  cost          Decimal?   @db.Decimal(12, 2)
  performedBy   String?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  turbineId     String
  createdById   String?
  documents          Document[]
