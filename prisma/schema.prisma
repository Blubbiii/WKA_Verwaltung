  OCR_PROCESSING
  REVIEW
  APPROVED
  PAID
  CANCELLED
}

enum IncomingOcrStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model Vendor {
  id          String   @id @default(uuid())
  tenantId    String
