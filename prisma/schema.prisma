  @@index([fundCategoryId])
  @@index([deletedAt])
  @@index([tenantId, deletedAt])
  @@map("funds")
}

/// Sprint 3 ABAC: User-spezifischer Fund-Whitelist-Eintrag.
/// Wenn FundAccess-Einträge für einen User existieren, kann der User NUR
/// die dort gelisteten Funds sehen. Wenn keine FundAccess-Einträge → keine
/// Restriktion (Default = Backward-Kompatibilität).
model FundAccess {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fundId    String
  fund      Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, fundId])
  @@index([userId])
  @@index([fundId])
  @@map("fund_access")
}

model FundPark {
  id                  String   @id @default(uuid())
  ownershipPercentage Decimal? @db.Decimal(5, 2)
  createdAt           DateTime @default(now())
  fundId              String
  parkId              String
  fund                Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
  park                Park     @relation(fields: [parkId], references: [id], onDelete: Cascade)

  @@unique([fundId, parkId])
  @@index([fundId])
  @@index([parkId])
  @@map("fund_parks")
}

