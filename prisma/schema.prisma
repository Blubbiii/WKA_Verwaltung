model IncomingInvoice {
  id                 String                @id @default(uuid())
  tenantId           String
  invoiceType        IncomingInvoiceType   @default(INVOICE)
  status             IncomingInvoiceStatus @default(INBOX)
  vendorId           String?
  vendorNameFallback String?               @db.VarChar(200)
  invoiceNumber      String?               @db.VarChar(100)
  invoiceDate        DateTime?
  dueDate            DateTime?
  netAmount          Decimal?              @db.Decimal(15, 2)
  vatAmount          Decimal?              @db.Decimal(15, 2)
  grossAmount        Decimal?              @db.Decimal(15, 2)
  vatRate            Decimal?              @db.Decimal(5, 2)
  currency           String                @default("EUR")
  iban               String?               @db.VarChar(34)
  bic                String?               @db.VarChar(11)
  paymentReference   String?               @db.VarChar(140)
  recipientFundId    String?
  ocrStatus          IncomingOcrStatus     @default(PENDING)
  ocrRawText         String?               @db.Text
  fileUrl            String
  fileName           String
  fileSizeBytes      BigInt?
  mimeType           String?
  paidAt             DateTime?
  paidAmount         Decimal?              @db.Decimal(15, 2)
  sepaExportedAt     DateTime?
  datevExportedAt    DateTime?
  datevAccount       String?               @db.VarChar(20)
  notes              String?               @db.Text
  createdById        String
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  deletedAt          DateTime?

  // P10: Tax-Code-Verweis (für §13b Reverse-Charge, IGE etc.)
  taxCodeId          String?
  taxCode            TaxCode?              @relation(fields: [taxCodeId], references: [id], onDelete: SetNull)
  // P11: §17 USt-Korrekturen die diese Eingangsrechnung referenzieren.
  ustAdjustments     UStAdjustment[]       @relation("UStAdjustmentIncoming")
  // P13: §14 UStG Pflichtangaben des Lieferanten (Pflicht für Vorsteuerabzug §15).
  supplierTaxId      String?               @db.VarChar(50)
  // P13: 4-Augen-Freigabe — approvedById MUSS ≠ createdById sein. Schwelle aus
  // TenantSettings.fourEyesThresholdEur (Null = keine Schwelle, immer 4-Augen).
  approvedById       String?
  approvedBy         User?                 @relation("IncomingInvoiceApprover", fields: [approvedById], references: [id], onDelete: Restrict)
  approvedAt         DateTime?

  vendor              Vendor?               @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  recipientFund       Fund?                 @relation(fields: [recipientFundId], references: [id], onDelete: SetNull)
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy           User                  @relation("IncomingInvoiceCreator", fields: [createdById], references: [id], onDelete: Restrict)
  splits              IncomingInvoiceSplit[]
  lines               IncomingInvoiceLine[]

  @@index([tenantId])
  @@index([vendorId])
  @@index([status])
  @@index([invoiceDate])
  @@index([dueDate])
  @@index([deletedAt])
  @@index([tenantId, deletedAt])
  // Composite-Index (Phase 7 M4): Dunning-Run filtert
  // WHERE tenantId=? AND status IN (...) AND dueDate < NOW()
  @@index([tenantId, status, dueDate])
  @@map("incoming_invoices")
}

model IncomingInvoiceLine {
  id          String          @id @default(uuid())
  invoiceId   String
  position    Int
  description String          @db.VarChar(500)
  netAmount   Decimal         @db.Decimal(15, 2)
