// =============================================================================
// P10: Zwei-Schichten-Steuermodell
//
// Schicht 1 — TaxCategoryTemplate (GLOBAL, ohne tenantId)
//   Vom Super-Admin gepflegte gesetzliche Steuer-Kategorien (§12 UStG, §13b,
//   §4, IGE/IGL, etc.) inkl. Default-Steuersatz und UStVA-Kennzahl.
//   Beim Tenant-Onboarding werden hieraus die TaxCodes für den Tenant
//   materialisiert (siehe Lib seedTenantTaxCodes()).
//
// Schicht 2 — TaxCode (TENANT-scoped)
//   Tenant-spezifische Materialisierung eines Templates: hält den DATEV-
//   Steuerschlüssel (z.B. "9" SKR04), das USt-Konto (z.B. "1776" SKR04)
//   und optionale Overrides (Name, abweichender Satz).
//   Wenn Override-Felder null sind, gelten die Template-Defaults.
//
// Das alte TaxType-Enum (STANDARD/REDUCED/EXEMPT) bleibt parallel bis
// P11/P12 es ablöst (Backwards-Compat).
// =============================================================================

enum TaxCategory {
  STANDARD_19              // §12 Abs. 1 UStG — Regelsteuersatz
  REDUCED_7                // §12 Abs. 2 UStG — ermäßigter Satz
  EXEMPT                   // §4 UStG — generell steuerfrei
  REVERSE_CHARGE_13B       // §13b UStG — Steuerschuldnerschaft Leistungsempfänger
  IGE_INTRA_EU             // innergemeinschaftlicher Erwerb (§1a UStG)
  IGL_INTRA_EU             // innergemeinschaftliche Lieferung (§4 Nr. 1b + §6a UStG)
  EXPORT                   // Drittlandsausfuhr (§4 Nr. 1a + §6 UStG)
  KLEINUNTERNEHMER_19      // §19 UStG — kein USt-Ausweis
  NOT_TAXABLE              // außerhalb USt-Bereich (z.B. Schadensersatz, Innenumsätze)
}

/// GLOBAL — wird vom Super-Admin gepflegt. Tenants sehen es read-only.
/// Beim Tenant-Onboarding werden hieraus die TaxCodes materialisiert.
model TaxCategoryTemplate {
  id                String      @id @default(uuid())
  /// Stabiler Identifier für Code-Lookups (z.B. "STANDARD_19").
  /// Entspricht dem TaxCategory-Enum-Namen.
  key               String      @unique @db.VarChar(50)
  category          TaxCategory @unique
  /// Anzeigename ("USt 19% Regelsteuersatz §12 Abs. 1 UStG").
  name              String      @db.VarChar(150)
  description       String?     @db.VarChar(500)
  /// Gesetzlicher Default-Satz (0.000 - 1.000). 19% = 0.19.
  defaultRate       Decimal     @db.Decimal(5, 4)
  /// UStVA-Kennzahl (z.B. "81", "46", "84"). Null bei NOT_TAXABLE / EXPORT.
  defaultVatReportBox String?   @db.VarChar(10)
  /// true für §13b + IGE (Leistungsempfänger schuldet USt).
  reverseCharge     Boolean     @default(false)
  /// Reihenfolge in UI-Listen.
  sortOrder         Int         @default(0)
  /// Aktiv = ist für Tenants nutzbar. Deaktivierte Templates werden bei
  /// neuem Tenant nicht mehr materialisiert, bestehende TaxCodes bleiben.
  active            Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  taxCodes          TaxCode[]

  @@index([active, sortOrder])
  @@map("tax_category_templates")
}

// =============================================================================
// P11: USt-Korrektur §17 UStG (Skonto, Gutschrift, Forderungsausfall,
//      Teilzahlung). Wird in §17-Mechanik gebraucht: nach Buchung der
//      Original-Rechnung müssen bei späteren Korrekturen Erlös + USt-Konto
//      gegengebucht werden. Audit-Trail über UStAdjustment-Zeile + Verweis
//      auf den erzeugten JournalEntry.
// =============================================================================

enum UStAdjustmentReason {
  SKONTO           // §17 Abs. 1 Nr. 1 UStG — Entgeltminderung durch Skonto
  CREDIT_NOTE      // §17 Abs. 1 — Rechnungsstorno / Korrekturrechnung
  WRITE_OFF        // §17 Abs. 2 Nr. 1 — Forderungsausfall (Uneinbringlichkeit)
  PARTIAL_PAYMENT  // §17 Abs. 2 Nr. 1 — Teil-Uneinbringlichkeit
  REVERSE_CHARGE   // §13b — Steuerschuldumkehr (Sonderfall, kein klassisches §17)
}

model UStAdjustment {
  id                        String              @id @default(uuid())
  tenantId                  String
  tenant                    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Referenz auf die korrigierte Ausgangsrechnung (für Skonto/Gutschrift/Ausfall).
  originalInvoiceId         String?
  originalInvoice           Invoice?            @relation("UStAdjustmentInvoice", fields: [originalInvoiceId], references: [id], onDelete: SetNull)
  /// Referenz auf die korrigierte Eingangsrechnung (z.B. eingehende Gutschrift).
  originalIncomingInvoiceId String?
  originalIncomingInvoice   IncomingInvoice?    @relation("UStAdjustmentIncoming", fields: [originalIncomingInvoiceId], references: [id], onDelete: SetNull)
  reason                    UStAdjustmentReason
  adjustmentDate            DateTime
  /// Delta zum Netto-Erlös (negativ bei Minderung, positiv bei Erhöhung).
  netAmountDelta            Decimal             @db.Decimal(15, 2)
  /// Delta zur USt-Schuld (Vorzeichen wie netAmountDelta).
  taxAmountDelta            Decimal             @db.Decimal(15, 2)
  /// Verweis auf den erzeugten JournalEntry (1:1 — jede Korrektur = eine
  /// neue Buchung, kein Inplace-Update der Original-Buchung).
  journalEntryId            String              @unique
  journalEntry              JournalEntry        @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  notes                     String?             @db.VarChar(500)
  createdById               String
  createdBy                 User                @relation("UStAdjustmentCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt                 DateTime            @default(now())

  @@index([tenantId, adjustmentDate])
  @@index([originalInvoiceId])
  @@index([originalIncomingInvoiceId])
  @@map("ust_adjustments")
}

model TaxCode {
  id            String              @id @default(uuid())
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Verweis auf das gesetzliche Template (Source of Truth für Kategorie,
  /// Default-Satz, UStVA-Box, reverseCharge). Required — wir lassen
  /// keine "freischwebenden" Codes zu.
  templateId    String
  template      TaxCategoryTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  /// DATEV-Steuerschlüssel des Tenants (z.B. "9" SKR04). Pro Tenant + Code UNIQUE.
  code          String              @db.VarChar(10)
  /// Tenant-spezifischer Name-Override (null = Template.name verwenden).
  nameOverride  String?             @db.VarChar(150)
  /// Tenant-spezifischer Satz-Override (selten, z.B. historische Sätze).
  /// Null = Template.defaultRate verwenden.
  rateOverride  Decimal?            @db.Decimal(5, 4)
  /// Tenant-spezifische UStVA-Kennzahl (null = Template.defaultVatReportBox).
  vatReportBoxOverride String?      @db.VarChar(10)
  /// SKR03/04 USt-Konto des Tenants (z.B. "1776" 19% USt SKR04).
  taxAccountId  String?
  taxAccount    LedgerAccount?      @relation("TaxCodeAccount", fields: [taxAccountId], references: [id], onDelete: SetNull)
  active        Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  invoices         Invoice[]
  incomingInvoices IncomingInvoice[]
  journalLines     JournalEntryLine[]

  /// Pro Tenant + Template genau EIN Code (Idempotenz beim Materialize).
  @@unique([tenantId, templateId])
  /// Pro Tenant Code UNIQUE (DATEV-Schlüssel-Kollision).
  @@unique([tenantId, code])
  @@index([tenantId, active])
  @@map("tax_codes")
}

