// =============================================================================
// ACCOUNTING MODULE — Kontenrahmen (SKR03)
// =============================================================================

enum AccountCategory {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

// P15: HGB §266 Bilanz-Gliederung (granularer als AccountCategory).
// Wird in der Bilanz-Aggregation pro Konto verwendet — das alte
// AccountCategory war zu grob (kein Anlagevermögen vs. Umlaufvermögen).
enum BalanceSheetSection {
  ASSET_FIXED         // A. Anlagevermögen
  ASSET_CURRENT       // B. Umlaufvermögen
  ASSET_DEFERRED      // C. Aktive Rechnungsabgrenzung
  EQUITY              // A. Eigenkapital
  PROVISION           // B. Rückstellungen
  LIABILITY_LONG      // C. Verbindlichkeiten (> 1 Jahr)
  LIABILITY_SHORT     // C. Verbindlichkeiten (< 1 Jahr)
  LIABILITY_DEFERRED  // D. Passive Rechnungsabgrenzung
}

enum TaxBehavior {
  TAXABLE_19
  TAXABLE_7
  EXEMPT
  INPUT_TAX
  OUTPUT_TAX
  NONE
}

model LedgerAccount {
  id            String          @id @default(uuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accountNumber String          @db.VarChar(10)
  name          String          @db.VarChar(200)
  category      AccountCategory
  taxBehavior   TaxBehavior     @default(NONE)
  isActive      Boolean         @default(true)
  isSystem      Boolean         @default(false)
  parentNumber  String?         @db.VarChar(10)
  notes         String?
  /// P10: Default-Steuerschlüssel für dieses Konto (DATEV-Schlüssel).
  /// Wird vom Auto-Posting (P11) als Vorbelegung verwendet.
  taxKey        String?         @db.VarChar(10)
  /// P15: HGB §266 Bilanz-Zuordnung. Wenn null, fällt der Bilanz-Generator
  /// auf SKR04-Range-Heuristik zurück (für Alt-Daten).
  balanceSheetSection BalanceSheetSection?
  /// P15: Single-Source-of-Truth für GuV/BWA-Klassifikation (z.B.
  /// "REVENUE_OPERATING", "EXPENSE_INTEREST"). Ersetzt schrittweise die
  /// Range-Hardcodes (account.startsWith("8")) in den Reports.
  category2     String?         @db.VarChar(50)
  /// P17: Gewerbesteuer-Hinzurechnung §8 GewStG-Schlüssel.
  /// Z.B. "MIETE_IMMOBILIEN" (1/2 Hinzurechnung), "MIETE_BEWEGLICH" (1/5).
  gewStAddBackKey String?       @db.VarChar(50)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  /// Rückrelation: TaxCodes können dieses Konto als USt-Konto referenzieren
  /// (z.B. TaxCode "USt 19%" → LedgerAccount "1776").
  taxCodesUsing TaxCode[]       @relation("TaxCodeAccount")

  /// P15: Saldenvortrag-Verweis (Eröffnungsbilanz pro Wirtschaftsjahr).
  openingBalances OpeningBalance[]

  @@unique([tenantId, accountNumber])
  @@index([tenantId])
  @@index([tenantId, category])
  @@index([tenantId, balanceSheetSection])
  @@map("ledger_accounts")
}

// P15: Saldenvortrag / Eröffnungsbilanz.
// Pro Wirtschaftsjahr + Konto + Tenant genau eine Zeile mit dem Buch-
// wert zum Jahreswechsel. Wird vom year-end-close-Job erzeugt und in
// der Bilanz-Aggregation als Startwert verwendet.
model OpeningBalance {
  id              String        @id @default(uuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fiscalYear      Int
  ledgerAccountId String
  ledgerAccount   LedgerAccount @relation(fields: [ledgerAccountId], references: [id], onDelete: Restrict)
  debitAmount     Decimal       @default(0) @db.Decimal(15, 2)
  creditAmount    Decimal       @default(0) @db.Decimal(15, 2)
  createdById     String
  createdBy       User          @relation("OpeningBalanceCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime      @default(now())

  @@unique([tenantId, fiscalYear, ledgerAccountId])
  @@index([tenantId, fiscalYear])
  @@map("opening_balances")
}

// P15: Bilanz-Snapshot. Bei jedem Jahresabschluss wird die Bilanz als
// JSON-Snapshot persistiert (Audit + Reproduzierbarkeit). Bei späteren
// Aufrufen sieht der User die zum Abschluss-Zeitpunkt gespeicherte
// Bilanz statt der laufend aktualisierten.
model BalanceSheetSnapshot {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fiscalYear   Int
  asOf         DateTime
  generatedAt  DateTime @default(now())
  /// {aktiva: [...], passiva: [...], summary: {summeAktiva, summePassiva, differenz}}
  snapshot     Json
  /// null = Tenant-weit (Einzel-Bilanz); gesetzt = Fund-spezifisch oder Konsolidiert.
  fundId       String?
  createdById  String
  createdBy    User     @relation("BalanceSheetSnapshotCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId, fiscalYear])
  @@index([tenantId, fundId])
  @@map("balance_sheet_snapshots")
}

// =============================================================================
// Bank Transactions — Persistent storage for imported bank statements
// =============================================================================

enum BankTxStatus {
  UNMATCHED
  SUGGESTED
  MATCHED
  IGNORED
}

/// Source of the match between a bank transaction and an invoice.
/// AUTO = matched by auto-matcher (heuristic). MANUAL = matched by user.
enum BankMatchSource {
  AUTO
  MANUAL
}

model BankTransaction {
  id                String        @id @default(uuid())
  tenantId          String
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fundId            String?
  fund              Fund?         @relation("BankTransactionFund", fields: [fundId], references: [id], onDelete: SetNull)
  bankAccountIban   String        @db.VarChar(34)
  bookingDate       DateTime
  amount            Decimal       @db.Decimal(15, 2)
  currency          String        @default("EUR") @db.VarChar(3)
  counterpartName   String?       @db.VarChar(200)
  counterpartIban   String?       @db.VarChar(34)
  reference         String?       @db.Text
  bankReference     String?       @db.VarChar(100)
  matchStatus       BankTxStatus  @default(UNMATCHED)
  matchedInvoiceId  String?
  matchedInvoice    Invoice?      @relation("BankTxMatchedInvoice", fields: [matchedInvoiceId], references: [id])
  matchConfidence   Float?
  /// GoBD-Audit: woher kommt die Zuordnung (AUTO-Matcher oder User)?
  matchSource       BankMatchSource?
  /// Welcher User hat die Zuordnung manuell bestätigt/angepasst?
  matchedById       String?
  /// Wann wurde die Zuordnung gesetzt?
  matchedAt         DateTime?
  importBatchId     String?       @db.VarChar(50)
  importFileName    String?       @db.VarChar(200)
  importedAt        DateTime      @default(now())
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  bankAccountId     String?
  bankAccount       BankAccount?  @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  // P16: Zahlungseingänge die dieser Bank-Transaktion zugeordnet sind.
  invoicePayments   InvoicePayment[]
  // P18: Match-Diagnostik — Skonto-Anteil und Cent-Differenz zur Rechnung.
  // Wenn matchedSkontoAmount > 0: die Differenz amount−grossAmount wurde
  // als gültiger Skonto akzeptiert (innerhalb Skonto-Frist).
  // matchVariance = |amount − grossAmount| (kann auch ohne Skonto > 0 sein
  // bei Toleranz-Match z.B. Rundungs-Differenz < 0,02 €).
  matchedSkontoAmount Decimal?    @db.Decimal(15, 2)
  matchVariance       Decimal?    @db.Decimal(15, 2)

  @@index([tenantId])
  @@index([tenantId, bookingDate])
  @@index([tenantId, matchStatus])
  @@index([importBatchId])
  @@index([bankAccountId])
  @@index([fundId])
  @@index([matchedInvoiceId])
  @@map("bank_transactions")
}

// =============================================================================
// Dunning (Mahnwesen)
// =============================================================================

enum DunningStatus {
  DRAFT
  EXECUTED
  CANCELLED
}

model DunningRun {
  id          String        @id @default(uuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  runDate     DateTime      @default(now())
  status      DunningStatus @default(DRAFT)
  createdById String
  createdBy   User          @relation("DunningRunCreatedBy", fields: [createdById], references: [id])
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  items       DunningItem[]

  @@index([tenantId])
  @@index([tenantId, runDate])
  @@map("dunning_runs")
}

// =============================================================================
// P16: Forderungsmanagement — Teilzahlungen, Verzugszinsen, Wertberichtigungen
// =============================================================================

enum InvoicePaymentMethod {
  BANK
  CASH
  SEPA
  OTHER
}

model InvoicePayment {
  id                String                @id @default(uuid())
  tenantId          String
  tenant            Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId         String
  invoice           Invoice               @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  paymentDate       DateTime
  amount            Decimal               @db.Decimal(15, 2)
  paymentMethod     InvoicePaymentMethod  @default(BANK)
  bankTransactionId String?
  bankTransaction   BankTransaction?      @relation(fields: [bankTransactionId], references: [id], onDelete: SetNull)
  journalEntryId    String?
  journalEntry      JournalEntry?         @relation("InvoicePaymentJournal", fields: [journalEntryId], references: [id], onDelete: SetNull)
  notes             String?               @db.VarChar(500)
  createdById       String
  createdBy         User                  @relation("InvoicePaymentCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt         DateTime              @default(now())

  @@index([tenantId, invoiceId])
  @@index([tenantId, paymentDate])
  @@map("invoice_payments")
}

enum ValueAdjustmentType {
  EWB              // Einzelwertberichtigung §253 HGB (zweifelhafte Forderung)
  PWB              // Pauschalwertberichtigung §253 HGB
  DIRECT_WRITEOFF  // Direkter Forderungsausfall §17 UStG
}

model ValueAdjustment {
  id              String              @id @default(uuid())
  tenantId        String
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId       String?
  invoice         Invoice?            @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  type            ValueAdjustmentType
  amountEur       Decimal             @db.Decimal(15, 2)
  reason          String              @db.VarChar(500)
  /// Wird bei DIRECT_WRITEOFF gesetzt — verweist auf den JournalEntry der
  /// die Ausbuchung + §17 USt-Korrektur enthält.
  postedJournalId String?             @unique
  postedJournal   JournalEntry?       @relation("ValueAdjustmentJournal", fields: [postedJournalId], references: [id], onDelete: Restrict)
  /// §17 USt-Korrektur (nur bei DIRECT_WRITEOFF mit USt-Bezug).
  ustAdjustmentId String?             @unique
  effectiveDate   DateTime
  createdById     String
  createdBy       User                @relation("ValueAdjustmentCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime            @default(now())

  @@index([tenantId, effectiveDate])
  @@index([invoiceId])
  @@map("value_adjustments")
}

// Audit-A: Globales SystemSetting für gesetzlich vorgegebene Werte.
// Mandantenunabhängig — wenn der Gesetzgeber z.B. den GWG-Schwellbetrag
// von 800 € auf 1.000 € ändert, sehen ALLE Tenants gleichzeitig den neuen
// Wert (kein Code-Deploy nötig).
//
// Validitätsbereich (validFrom/validTo) ist optional — er erlaubt es,
// historisch gültige Werte zu archivieren (z.B. GewSt-Freibetrag war
// 100k vor 2020, ist 200k seitdem).
model SystemSetting {
  key         String    @id @db.VarChar(100)
  /// Wert als JSON. Konsumenten typen das per Helper getSystemSetting<T>().
  value       Json
  /// Logische Gruppe (UI-Filter): "GWG", "GEWST", "VERZUGSZINS", "USTG", "AFA".
  category    String    @db.VarChar(50)
  description String?   @db.VarChar(500)
  validFrom   DateTime?
  validTo     DateTime?
  updatedById String
  updatedBy   User      @relation("SystemSettingUpdater", fields: [updatedById], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([category])
  @@map("system_settings")
}

// P19: GoBD §147 Abs. 6 AO Datenträgerüberlassung (Z3).
// Audit der erzeugten Export-ZIPs. Wird bei Betriebsprüfung vorgelegt —
// daher fileHash + size persistiert. ZIP selbst wird nicht in der DB
// gespeichert (potentiell mehrere GB), nur Download-Link über fileUrl.
model GobdExport {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  periodFrom     DateTime
  periodTo       DateTime
  generatedAt    DateTime @default(now())
  /// SHA-256 des erzeugten ZIPs (Hex).
  fileHash       String   @db.VarChar(64)
  fileSizeBytes  BigInt
  /// Wieviele Datensätze pro Tabelle exportiert wurden (für Audit-Log + UI).
  recordCounts   Json
  /// Optional: Pfad/URL zum gespeicherten ZIP (S3 / Filesystem). Null wenn
  /// nur im Memory ausgeliefert wurde.
  fileUrl        String?
  downloadCount  Int      @default(0)
  lastDownloadAt DateTime?
  createdById    String
  createdBy      User     @relation("GobdExportCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId, periodFrom])
  @@index([tenantId, generatedAt])
  @@map("gobd_exports")
}

// §247 BGB Basiszinssatz (Bundesbank). Mandantenunabhängig — wir pflegen
// die Zeitreihe einmal global. Die effektive Verzugszinsformel ist
// BaseRate + 5%-Pkt (B2C) oder + 9%-Pkt (B2B).
model BaseInterestRate {
  id          String   @id @default(uuid())
  validFrom   DateTime @db.Date
  validTo     DateTime? @db.Date
  ratePercent Decimal  @db.Decimal(6, 3)
  /// Quelle (z.B. "Bundesbank BBK01.SU0316").
  source      String   @db.VarChar(200)
  createdAt   DateTime @default(now())

  @@unique([validFrom])
  @@index([validFrom, validTo])
  @@map("base_interest_rates")
}

model DunningItem {
  id            String     @id @default(uuid())
  dunningRunId  String
  dunningRun    DunningRun @relation(fields: [dunningRunId], references: [id], onDelete: Cascade)
  invoiceId     String
  invoice       Invoice    @relation("DunningItemInvoice", fields: [invoiceId], references: [id], onDelete: Cascade)
  level         Int        @default(1) // Mahnstufe 1-3
  overdueDays   Int
  amount        Decimal    @db.Decimal(15, 2)
  feeAmount     Decimal    @default(0) @db.Decimal(15, 2)
  // P16 §288 BGB Verzugszinsen.
  // B2B: Basiszinssatz + 9 %-Punkte (Abs. 2). B2C: Basis + 5 %-Punkte (Abs. 1).
  interestAmount      Decimal @default(0) @db.Decimal(15, 2)
  interestRatePercent Decimal? @db.Decimal(6, 3)
  interestDaysOverdue Int?
  // §288 Abs. 5: 40€-Pauschale für B2B-Forderungen (einmalig pro Forderung).
  interestLumpSumEur  Decimal @default(0) @db.Decimal(10, 2)
  letterPdfUrl  String?
  emailSentAt   DateTime?
  createdAt     DateTime   @default(now())

  @@index([dunningRunId])
  @@index([invoiceId])
  @@map("dunning_items")
}

// =============================================================================
// SEPA Payment Batches
