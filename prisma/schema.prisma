// =============================================================================
// Fixed Assets (Anlagenbuchhaltung)
// =============================================================================

enum DepreciationMethod {
  LINEAR
  DECLINING_BALANCE
}

// P14: §7 EStG AfA-Methoden + §6 EStG GWG-Behandlung.
// Ersetzt schrittweise das alte DepreciationMethod-Enum (das nur LINEAR/
// DECLINING_BALANCE kennt). DECLINING_BALANCE ist seit Anschaffungen ab
// 01.01.2023 unzulässig (§7 Abs. 2 EStG i.V.m. Übergangsregeln) — wird
// vom Engine bei neuen Assets geblockt.
enum AfaMethod {
  LINEAR             // §7 Abs. 1 EStG (Standardfall)
  GWG_SOFORT         // §6 Abs. 2 EStG — Sofortabzug bis 800 € Netto
  GWG_POOL           // §6 Abs. 2a EStG — Sammelposten 250-1.000 € über 5 Jahre
  DECLINING_BALANCE  // §7 Abs. 2 EStG — degressiv (nur für Altanlagen vor 2023)
}

enum AssetStatus {
  ACTIVE
  DISPOSED
  FULLY_DEPRECIATED
}

model FixedAsset {
  id                  String              @id @default(uuid())
  tenantId            String
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assetNumber         String              @db.VarChar(20)
  name                String              @db.VarChar(200)
  description         String?
  category            String              @db.VarChar(50)
  acquisitionDate     DateTime
  acquisitionCost     Decimal             @db.Decimal(15, 2)
  usefulLifeMonths    Int
  /// @deprecated P14: Nutze afaMethod stattdessen. Bleibt für Backwards-
  /// Compat erhalten — bestehende Assets ohne afaMethod werden hieraus
  /// gemappt (LINEAR → LINEAR, DECLINING_BALANCE → DECLINING_BALANCE).
  depreciationMethod  DepreciationMethod  @default(LINEAR)
  /// P14: §7/§6 EStG-konforme Methoden inkl. GWG. Nullable während Migration —
  /// wenn null, fällt der Engine auf depreciationMethod zurück.
  afaMethod           AfaMethod?
  /// P14: GWG-Sammelposten-Jahrgang (§6 Abs. 2a EStG). Nur relevant wenn
  /// afaMethod=GWG_POOL. Jahr des Anschaffungsjahrgangs zur Pool-Identifikation.
  gwgPoolYear         Int?
  residualValue       Decimal             @default(0) @db.Decimal(15, 2)
  accountNumber       String?             @db.VarChar(10) // SKR03 asset account
  depAccountNumber    String?             @db.VarChar(10) // SKR03 depreciation expense account
  status              AssetStatus         @default(ACTIVE)
  disposalDate        DateTime?
  disposalProceeds    Decimal?            @db.Decimal(15, 2)
  notes               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  depreciations       FixedAssetDepreciation[]

  @@unique([tenantId, assetNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("fixed_assets")
}

model FixedAssetDepreciation {
  id            String     @id @default(uuid())
  assetId       String
  asset         FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  periodStart   DateTime
  periodEnd     DateTime
  amount        Decimal    @db.Decimal(15, 2)
  /// Buchwert VOR dieser AfA-Buchung. P14: Nachträglich nullable hinzugefügt
  /// — alte Schedule-Rows haben null, neue werden gefüllt. Erlaubt die
  /// Anlagespiegel-Erstellung (vergleicht book-value-Verlauf).
  bookValueBefore Decimal? @db.Decimal(15, 2)
  bookValue     Decimal    @db.Decimal(15, 2) // remaining book value after this depreciation
  journalEntryId String?
  createdAt     DateTime   @default(now())

  @@index([assetId])
  @@index([assetId, periodStart])
  @@map("fixed_asset_depreciations")
}

// =============================================================================
// Cash Book (Kassenbuch)
// =============================================================================

model CashBookEntry {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entryDate     DateTime
  entryNumber   Int
  description   String   @db.VarChar(200)
  amount        Decimal  @db.Decimal(15, 2) // positive = income, negative = expense
  runningBalance Decimal @db.Decimal(15, 2)
  account       String?  @db.VarChar(10) // SKR03 counter-account
  receiptNumber String?  @db.VarChar(50)
  createdById   String
  createdBy     User     @relation("CashBookEntryCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // P26.2 §146 AO Festschreibung — nach Lock keine Änderung mehr möglich.
  // Locked-Block wird vom CashBookLock-Eintrag referenziert (Tag-genau).
  lockedAt      DateTime?
  lockedById    String?
  lockedBy      User?    @relation("CashBookEntryLocker", fields: [lockedById], references: [id], onDelete: Restrict)

  @@unique([tenantId, entryNumber])
  @@index([tenantId, entryDate])
  @@map("cash_book_entries")
}

/// P26.2 Kassensturz §146 AO — Tagesabschluss mit Soll/Ist-Vergleich.
/// Hält den tatsächlich gezählten Kassenbestand am Tagesende fest und
/// vergleicht ihn mit dem rechnerischen Saldo. Differenz muss begründet
/// werden (z.B. fehlender Beleg).
model CashBookDailyClose {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  closeDate       DateTime @db.Date
  /// Rechnerischer Saldo = letzter runningBalance des Tages.
  computedBalance Decimal  @db.Decimal(15, 2)
  /// Tatsächlich gezählter Bargeldbestand.
  countedBalance  Decimal  @db.Decimal(15, 2)
  /// Differenz = countedBalance − computedBalance.
  difference      Decimal  @db.Decimal(15, 2)
  /// Pflichtfeld bei Differenz ≠ 0.
  notes           String?  @db.VarChar(500)
  closedById      String
  closedBy        User     @relation("CashBookDailyClosedBy", fields: [closedById], references: [id], onDelete: Restrict)
  closedAt        DateTime @default(now())

  @@unique([tenantId, closeDate])
  @@index([tenantId, closeDate])
  @@map("cash_book_daily_closes")
}

// =============================================================================
// Document Routing Rules (OneDrive / DATEV folder mapping)
// =============================================================================

model DocumentRoutingRule {
  id            String      @id @default(uuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fundId        String?
  fund          Fund?       @relation(fields: [fundId], references: [id], onDelete: SetNull)
  invoiceType   InvoiceType // INVOICE or CREDIT_NOTE
  targetPath    String      @db.VarChar(500) // e.g. "41068-BIH GmbH -> Rechnungseingang"
  targetType    String      @default("onedrive") @db.VarChar(50) // onedrive, smb, dropbox
  isActive      Boolean     @default(true)
  description   String?     @db.VarChar(200)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([tenantId, fundId, invoiceType, targetType])
  @@index([tenantId])
  @@map("document_routing_rules")
}

// =============================================================================
// BETRIEBSFÜHRUNG — OPERATIVE SUB-MODULE
// =============================================================================

enum OperationalTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ClaimStatus {
  REPORTED
  CLAIM_IN_PROGRESS
  RESOLVED
  REJECTED
}

enum DefectSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model OperationalChecklist {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String   @db.VarChar(200)
  description String?  @db.Text
  items       Json     @default("[]")
  recurrence  String?  @db.VarChar(50)
  parkId      String?
  park        Park?    @relation(fields: [parkId], references: [id], onDelete: SetNull)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       OperationalTask[]

  @@index([tenantId])
  @@index([parkId])
  @@map("operational_checklists")
}

model OperationalTask {
  id              String                @id @default(uuid())
  tenantId        String
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title           String                @db.VarChar(200)
  description     String?               @db.Text
  status          OperationalTaskStatus @default(OPEN)
  priority        Int                   @default(2)
  taskType        String                @default("OPERATIONAL") @db.VarChar(30)
  category        String?               @db.VarChar(100)
  dueDate         DateTime?
  completedAt     DateTime?
  notes           String?               @db.Text
  checklistData   Json?
  costEstimateEur Decimal?              @db.Decimal(12, 2)
  actualCostEur   Decimal?              @db.Decimal(12, 2)
  benefitNotes    String?               @db.Text
  parkId          String?
  park            Park?                 @relation(fields: [parkId], references: [id], onDelete: SetNull)
  turbineId       String?
  turbine         Turbine?              @relation(fields: [turbineId], references: [id], onDelete: SetNull)
  checklistId     String?
  checklist       OperationalChecklist? @relation(fields: [checklistId], references: [id], onDelete: SetNull)
  assignedToId    String?
  assignedTo      User?                 @relation("OperationalTaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById     String
  createdBy       User                  @relation("OperationalTaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([tenantId])
  @@index([parkId])
  @@index([status])
  @@index([dueDate])
  @@index([assignedToId])
  @@index([taskType])
  // Composite (Phase 7 M4): "alle überfälligen offenen Tasks dieses Tenants"
  @@index([tenantId, status, dueDate])
  @@map("operational_tasks")
}

model InspectionPlan {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title        String    @db.VarChar(200)
  description  String?   @db.Text
  recurrence   String    @db.VarChar(50)
  nextDueDate  DateTime
  lastExecuted DateTime?
  parkId       String?
  park         Park?     @relation(fields: [parkId], references: [id], onDelete: SetNull)
  turbineId    String?
  turbine      Turbine?  @relation(fields: [turbineId], references: [id], onDelete: SetNull)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  inspectionReports InspectionReport[]

  @@index([tenantId])
  @@index([nextDueDate])
  @@index([parkId])
  @@map("inspection_plans")
}

model InspectionReport {
  id               String          @id @default(uuid())
  tenantId         String
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inspectionPlanId String?
  inspectionPlan   InspectionPlan? @relation(fields: [inspectionPlanId], references: [id], onDelete: SetNull)
  serviceEventId   String?
  serviceEvent     ServiceEvent?   @relation(fields: [serviceEventId], references: [id], onDelete: SetNull)
  inspectionDate   DateTime
  inspector        String?         @db.VarChar(200)
  result           String?         @db.VarChar(50)
  summary          String?         @db.Text
  parkId           String?
  park             Park?           @relation(fields: [parkId], references: [id], onDelete: SetNull)
  turbineId        String?
  turbine          Turbine?        @relation(fields: [turbineId], references: [id], onDelete: SetNull)
  createdById      String
  createdBy        User            @relation("InspectionReportCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  defects          Defect[]

  @@index([tenantId])
  @@index([inspectionDate])
  @@index([parkId])
  @@map("inspection_reports")
}

model Defect {
  id                 String                @id @default(uuid())
  tenantId           String
  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title              String                @db.VarChar(200)
  description        String?               @db.Text
  severity           DefectSeverity        @default(MEDIUM)
  status             OperationalTaskStatus @default(OPEN)
  dueDate            DateTime?
  resolvedAt         DateTime?
  resolutionNotes    String?               @db.Text
  costEstimateEur    Decimal?              @db.Decimal(12, 2)
  actualCostEur      Decimal?              @db.Decimal(12, 2)
  inspectionReportId String?
  inspectionReport   InspectionReport?     @relation(fields: [inspectionReportId], references: [id], onDelete: SetNull)
  parkId             String?
  park               Park?                 @relation(fields: [parkId], references: [id], onDelete: SetNull)
  turbineId          String?
  turbine            Turbine?              @relation(fields: [turbineId], references: [id], onDelete: SetNull)
  createdById        String
  createdBy          User                  @relation("DefectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  insuranceClaims    InsuranceClaim[]

  @@index([tenantId])
  @@index([severity])
  @@index([status])
  @@index([dueDate])
  @@index([parkId])
  // Composite (Phase 7 M4): offene Mängel deren Frist abläuft
  @@index([tenantId, status, dueDate])
  @@map("defects")
}

model InsuranceClaim {
  id               String      @id @default(uuid())
  tenantId         String
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  claimNumber      String?     @db.VarChar(100)
  title            String      @db.VarChar(200)
  description      String?     @db.Text
  incidentDate     DateTime
  reportedDate     DateTime    @default(now())
  status           ClaimStatus @default(REPORTED)
  claimType        String      @db.VarChar(50)
  estimatedCostEur Decimal?    @db.Decimal(12, 2)
  actualCostEur    Decimal?    @db.Decimal(12, 2)
  reimbursedEur    Decimal?    @db.Decimal(12, 2)
  resolvedAt       DateTime?
  resolutionNotes  String?     @db.Text
  contractId       String?
  contract         Contract?   @relation(fields: [contractId], references: [id], onDelete: SetNull)
  vendorId         String?
  vendor           Vendor?     @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  defectId         String?
  defect           Defect?     @relation(fields: [defectId], references: [id], onDelete: SetNull)
  parkId           String?
  park             Park?       @relation(fields: [parkId], references: [id], onDelete: SetNull)
  turbineId        String?
  turbine          Turbine?    @relation(fields: [turbineId], references: [id], onDelete: SetNull)
  createdById      String
  createdBy        User        @relation("InsuranceClaimCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([contractId])
  @@index([parkId])
  @@index([incidentDate])
  @@map("insurance_claims")
}

// =============================================================================
// PPA (Power Purchase Agreement) Management
// =============================================================================

enum PpaPricingMode {
  FIXED         // Festpreis (ct/kWh)
  INDEXED       // Indexbasiert (Basispreis + Aufschlag)
  COLLAR        // Floor + Cap
}

enum PpaStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

model PowerPurchaseAgreement {
  id                  String         @id @default(uuid())
  title               String
  contractNumber      String?
  counterparty        String         // Vertragspartner
  pricingMode         PpaPricingMode @default(FIXED)
  fixedPriceCentKwh   Decimal?       @db.Decimal(8, 4)  // Festpreis in ct/kWh
  floorPriceCentKwh   Decimal?       @db.Decimal(8, 4)  // Collar Floor
  capPriceCentKwh     Decimal?       @db.Decimal(8, 4)  // Collar Cap
  indexBase           String?        // z.B. "EPEX Day-Ahead"
  indexMarkupCentKwh  Decimal?       @db.Decimal(8, 4)  // Aufschlag auf Index
  minQuantityMwh      Decimal?       @db.Decimal(12, 3) // Mindestliefermenge/Jahr
  maxQuantityMwh      Decimal?       @db.Decimal(12, 3) // Höchstliefermenge/Jahr
  billingPeriod       String         @default("MONTHLY") // MONTHLY, QUARTERLY, YEARLY
  startDate           DateTime
  endDate             DateTime
  status              PpaStatus      @default(DRAFT)
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  parkId              String
  park                Park           @relation(fields: [parkId], references: [id], onDelete: Cascade)
  tenantId            String
  tenant              Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([parkId])
  @@index([status])
  @@map("power_purchase_agreements")
}

// =============================================================================
// Email Routing (Catch-All → Park/Fund/Tenant Zuordnung)
// =============================================================================

model EmailRoute {
  id          String   @id @default(uuid())
  address     String   // Email-Prefix vor @ (z.B. "windpark-nord")
  targetType  String   // "PARK" | "FUND" | "TENANT" | "INBOX"
  targetId    String   // UUID des Ziel-Entities
  description String?  // Freitext-Beschreibung
  isActive    Boolean  @default(true)
  autoAction  String   @default("INBOX") // "INBOX" | "DOCUMENT" | "IGNORE"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([address, tenantId])
  @@index([tenantId])
  @@index([address])
  @@map("email_routes")
}

model InboundEmail {
  id            String   @id @default(uuid())
  fromAddress   String
  toAddress     String
  subject       String?
  textBody      String?  @db.Text
  htmlBody      String?  @db.Text
  receivedAt    DateTime
  status        String   @default("RECEIVED") // RECEIVED | PROCESSED | FAILED | IGNORED
  routeId       String?  // Matched EmailRoute
  targetType    String?  // Resolved target type
  targetId      String?  // Resolved target ID
  attachmentCount Int    @default(0)
  processingNotes String? @db.Text
  createdAt     DateTime @default(now())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([toAddress])
  @@index([status])
  @@map("inbound_emails")
}

// =============================================================================
// Permissions v2 (Sprint 3) — Approval-Workflow für 4-Augen-pflichtige Aktionen
// =============================================================================

/// Status einer Approval-Anfrage.
enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

/// Aktion die genehmigt werden soll.
enum ApprovalAction {
  JOURNAL_POST
  JOURNAL_REVERSE
  SETTLEMENT_FINALIZE
  SEPA_RUN
  TENANT_SETTINGS_UPDATE
  USER_ROLE_ASSIGN
  INCOMING_INVOICE_APPROVE
}

/// Approval-Request für 4-Augen-Prinzip. Wird erzeugt wenn der initiierende
/// User die Aktion nicht alleine ausführen darf (Self-Approval-Verbot oder
/// betraglicher Schwellwert überschritten). Ein zweiter berechtigter User
/// approved/rejected das Request. Beim Approve wird die ursprüngliche
/// Aktion durchgeführt (idempotent: gleiche Entity, gleiche Daten).
model ApprovalRequest {
  id              String          @id @default(uuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  action          ApprovalAction
  /// Entity die genehmigt wird (z.B. "JournalEntry", "SepaPaymentBatch").
  entityType      String          @db.VarChar(50)
  /// Entity-Primärschlüssel.
  entityId        String
  /// Betrag in EUR (für Schwellwert-Logik + Audit).
  amountEur       Decimal?        @db.Decimal(15, 2)
  /// Aktion-spezifische Parameter (JSON), die der Executor beim Approve
  /// durchführen muss. Beispiel: reverseReason für Storno, oder die
  /// debtorIban/-Name für SEPA-Lauf. Leer für simple Aktionen die nur
  /// entityId brauchen.
  actionParams    Json?
  /// Ausführungs-Ergebnis nach APPROVED + erfolgreichem Execute.
  /// Beispiel: { executedEntityId: "uuid-of-reversal" }
  executionResult Json?
  /// Fehler-Message wenn Execute nach APPROVED scheiterte.
  executionError  String?         @db.VarChar(500)
  /// Zeitpunkt der Aktion-Ausführung (kann später sein als decidedAt).
  executedAt      DateTime?

  /// Initiator (der die Aktion ausführen will).
  requestedById   String
  requestedBy     User            @relation("ApprovalRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  requestedAt     DateTime        @default(now())
  /// Begründung für die Aktion (frei).
  requestReason   String?         @db.VarChar(500)

  status          ApprovalStatus  @default(PENDING)

  /// Genehmigender User (NULL solange PENDING).
  decidedById     String?
  decidedBy       User?           @relation("ApprovalDecider", fields: [decidedById], references: [id], onDelete: Restrict)
  decidedAt       DateTime?
  /// Bei REJECTED: Begründung des Genehmigers.
  decisionReason  String?         @db.VarChar(500)

  /// Approval läuft nach 7 Tagen aus (cron setzt auf EXPIRED).
  expiresAt       DateTime

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([tenantId, status])
  @@index([entityType, entityId])
  @@index([requestedById])
  @@index([decidedById])
  @@index([expiresAt])
  @@map("approval_requests")
}
