  poolSharePercentage                    Decimal?                    @db.Decimal(5, 2)
  wegCompensationPerSqm                  Decimal?                    @db.Decimal(10, 2)
  ausgleichCompensationPerSqm            Decimal?                    @db.Decimal(10, 2)
  kabelCompensationPerM                  Decimal?                    @db.Decimal(10, 2)
