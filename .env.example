# =====================================================
# WindparkManager - Environment Variables
# Copy this file to .env and fill in your values
# =====================================================

# ===========================================
# Application
# ===========================================
NODE_ENV=production
APP_NAME=WindparkManager
NEXTAUTH_URL=https://wpm.example.com
NEXT_PUBLIC_APP_URL=https://wpm.example.com

# Auth.js v5 uses AUTH_SECRET (set BOTH for compatibility)
AUTH_SECRET=your-auth-secret-min-32-chars
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# App version (set by CI/CD or manually)
# NEXT_PUBLIC_APP_VERSION=1.0.0

# ===========================================
# Database (PostgreSQL)
# ===========================================
POSTGRES_USER=wpm
POSTGRES_PASSWORD=your-secure-database-password
POSTGRES_DB=windparkmanager
DATABASE_URL=postgresql://wpm:your-secure-database-password@db:5432/windparkmanager

# pg_dump credentials (used by backup scripts)
# PGHOST=db
# PGPORT=5432
# PGUSER=wpm
# PGPASSWORD=your-secure-database-password
# PGDATABASE=windparkmanager

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://:your-redis-password@redis:6379
REDIS_PASSWORD=your-redis-password

# Redis tuning (optional)
# REDIS_CACHE_CONNECT_TIMEOUT_MS=5000
# REDIS_CACHE_MAX_RETRIES=3
# REDIS_RATELIMIT_CONNECT_TIMEOUT_MS=5000
# REDIS_RATELIMIT_MAX_RETRIES=3

# ===========================================
# Worker (Background Jobs)
# ===========================================
# Start mode: 'app' for Next.js server, 'worker' for background jobs
START_MODE=app
# Number of concurrent jobs per worker instance
WORKER_CONCURRENCY=5
# Number of worker replicas in production (docker-compose.prod.yml)
WORKER_REPLICAS=2

# ===========================================
# S3 Storage (MinIO / AWS S3)
# ===========================================
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_BUCKET=wpm-documents
S3_REGION=us-east-1

# Storage type: 's3' (default) or 'local'
# STORAGE_TYPE=s3

# MinIO container credentials (docker-compose only)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your-minio-password

# ===========================================
# Email (SMTP) - System Fallback
# ===========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME=WindparkManager

# Aliases (some code uses these — set same values)
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_FROM_NAME=WindparkManager

# Email encryption key (64 hex chars — for DB-stored SMTP credentials)
# Generate with: openssl rand -hex 32
EMAIL_ENCRYPTION_KEY=your-64-character-hex-key-here

# SMTP Timeouts (optional, defaults in ms)
# SMTP_CONNECTION_TIMEOUT_MS=10000
# SMTP_GREETING_TIMEOUT_MS=10000
# SMTP_SOCKET_TIMEOUT_MS=30000
# SENDGRID_TIMEOUT_MS=30000

# ===========================================
# SCADA (Enercon WSD Import)
# ===========================================
# API key for n8n/PowerShell upload scripts
SCADA_API_KEY=your-scada-api-key
# Path to SCADA data directory (inside container)
SCADA_BASE_PATH=/data/scada
# NEXT_PUBLIC_SCADA_BASE_PATH=/data/scada

# ===========================================
# Cron Jobs (Deadline Checker etc.)
# ===========================================
# Bearer token for /api/cron/* endpoints
CRON_SECRET=your-cron-secret-min-32-chars

# ===========================================
# SSO (Authentik — optional)
# ===========================================
# AUTHENTIK_ISSUER=https://auth.example.com/application/o/wpm
# AUTHENTIK_CLIENT_ID=your-client-id
# AUTHENTIK_CLIENT_SECRET=your-client-secret
# AUTHENTIK_DISPLAY_NAME=Single Sign-On

# ===========================================
# Meilisearch (optional — Volltextsuche)
# ===========================================
# MEILISEARCH_URL=http://meilisearch:9700
# MEILISEARCH_KEY=your-meilisearch-master-key
# MEILISEARCH_ENABLED=false

# ===========================================
# Monitoring & Metrics
# ===========================================
# Prometheus metrics endpoint token
# METRICS_TOKEN=your-random-32-char-token
# PROMETHEUS_URL=http://prometheus:9090

# Requests slower than this (ms) are logged as warnings
SLOW_REQUEST_THRESHOLD=2000

# Trusted proxy IPs (comma-separated, for rate limiting)
# TRUSTED_PROXY_IPS=172.16.0.0/12,10.0.0.0/8

# ===========================================
# Logging
# ===========================================
# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# ===========================================
# Error Tracking (Sentry)
# ===========================================
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ===========================================
# Weather (Open-Meteo — FREE, no key required)
# ===========================================
WEATHER_CACHE_TTL=1800
WEATHER_SYNC_INTERVAL=30

# ===========================================
# Database Backup
# ===========================================
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=3
# BACKUP_DIR=/backups

# S3 backup storage (optional)
# BACKUP_S3_ENABLED=false
# BACKUP_S3_BUCKET=wpm-backups
# BACKUP_S3_ENDPOINT=http://minio:9000

# ===========================================
# API Limits (optional — sensible defaults exist)
# ===========================================
# BATCH_MAX_SIZE=50
# MAX_EXPORT_ENTRIES=10000
# ZIP_MAX_FILES=200
# ZIP_MAX_SIZE_MB=500
# SIGNED_URL_EXPIRES=3600
# SCADA_PREVIEW_MAX_RECORDS=500
# GIS_MAX_FEATURES_PER_LAYER=5000
# GIS_MAX_FILE_SIZE_MB=50

# ===========================================
# Auth Config (optional — sensible defaults exist)
# ===========================================
# SESSION_MAX_AGE=86400
# BCRYPT_SALT_ROUNDS=12
# PASSWORD_MIN_LENGTH=8
# PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1
# IMPERSONATION_MAX_AGE=3600

# ===========================================
# Tenant Limits (optional)
# ===========================================
# DEFAULT_TENANT_MAX_USERS=50
# DEFAULT_TENANT_MAX_STORAGE_MB=5000
# DEFAULT_TENANT_MAX_PARKS=20

# ===========================================
# SSL/TLS (Let's Encrypt)
# ===========================================
# ACME_EMAIL=admin@example.com

# ===========================================
# n8n Workflow Automation
# ===========================================
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=your-n8n-password

# ===========================================
# Traefik Dashboard (optional)
# Generate with: htpasswd -nb admin password
# ===========================================
# TRAEFIK_DASHBOARD_AUTH=admin:$apr1$xyz...
